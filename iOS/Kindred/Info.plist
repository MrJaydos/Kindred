<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- TODO: Replace placeholder strings with real ones when HealthKit/Motion integration lands -->
	<key>NSHealthShareUsageDescription</key>
	<string>TODO: Kindred reads your steps and active hours to grow your creature. All processing happens on-device.</string>
	<key>NSMotionUsageDescription</key>
	<string>TODO: Kindred reads your motion data to understand your activity patterns. All processing happens on-device.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>TODO: Kindred uses Bluetooth to connect with nearby tamers for battles. No data leaves your device.</string>
	<key>NFCReaderUsageDescription</key>
	<string>TODO: Kindred uses NFC to pair with nearby tamers by tapping phones together.</string>
</dict>
</plist>
